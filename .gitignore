# .gitignore

```gitignore
# ==========================================================
# Python
# ==========================================================
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / Packaging
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ==========================================================
# Virtual Environments
# ==========================================================
.venv/
venv/
env/
ENV/

# ==========================================================
# Test / Coverage
# ==========================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache/

# Ruff / Lint
.ruff_cache/

# MyPy
.mypy_cache/

# Pyre
.pyre/

# ==========================================================
# IDEs
# ==========================================================
.vscode/
.idea/
*.code-workspace

# ==========================================================
# Operating System
# ==========================================================
.DS_Store
Thumbs.db
desktop.ini

# ==========================================================
# Logs
# ==========================================================
*.log
logs/

# ==========================================================
# Runtime Database Files
# ==========================================================
data/
*.wal
*.sst
*.manifest

# ==========================================================
# Benchmark Results (optional)
# Uncomment if you don't want benchmark outputs committed.
# ==========================================================
# benchmarks/results/*

# ==========================================================
# Documentation Assets
# Uncomment if you don't want large recordings committed.
# ==========================================================
# docs/videos/
# *.mp4

# ==========================================================
# Docker
# ==========================================================
*.pid

# ==========================================================
# Temporary Files
# ==========================================================
*.tmp
*.temp
*.bak
*.swp
```
