# Exclude development and runtime artifacts from Docker build context.
# This dramatically speeds up `docker compose up --build`.

# Python artifacts
**/__pycache__
**/*.pyc
**/*.pyo
**/*.egg-info
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/.venv
**/venv

# Node.js artifacts
**/node_modules
**/dist
**/.next

# Data / WAL / SSTables (KV store runtime data)
lsmkv/data/

# Git
**/.git
**/.gitignore

# IDE
**/.vscode
**/.idea

# OS
**/.DS_Store
**/Thumbs.db

# Docs that don't affect runtime
**/docs
**/*.md
