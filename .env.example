# Copy this to .env and fill in values for your environment.
# Used by docker compose (it auto-loads .env from the project root).

# Public port for the dashboard container (default: 80).
# Railway / Render automatically sets PORT for you.
PORT=80

# ── Vercel split-deployment only ─────────────────────────────────────────────
# Set this in Vercel's Environment Variables dashboard (NOT here).
# Your Railway/Render API URL, e.g.:
#   VITE_API_URL=https://my-kv-api.up.railway.app
# Leave unset for Railway / Render full-stack deployments (Nginx handles routing).
# VITE_API_URL=
